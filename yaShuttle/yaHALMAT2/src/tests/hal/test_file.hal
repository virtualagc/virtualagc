 TEST_FILE_REAL:
 PROGRAM;
    DECLARE INTEGER, I1 INITIAL(42);
    DECLARE INTEGER, I2;
    DECLARE INTEGER, I3;
    DECLARE SCALAR, S1 INITIAL(3.5);
    DECLARE SCALAR, S2;
    FILE(1, 0) = I1;
    FILE(1, 1) = S1;
    I2 = FILE(1, 0);
    S2 = FILE(1, 1);
    I1 = 99;
    FILE(1, 0) = I1;
    I3 = FILE(1, 0);
    WRITE(6) I2;
    WRITE(6) S2;
    WRITE(6) I3;
 CLOSE TEST_FILE_REAL;
