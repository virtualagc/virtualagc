 TEST_CHAR_CONV:
 PROGRAM;
    DECLARE INTEGER, I1 INITIAL(42);
    DECLARE SCALAR, S1 INITIAL(3.5);
    DECLARE CHARACTER(20), C1, C2, C3;
    DECLARE CHARACTER(20), C4 INITIAL('123');
    DECLARE CHARACTER(20), C5 INITIAL('7.5');
    DECLARE INTEGER, I2;
    DECLARE SCALAR, S2;
    C1 = CHARACTER(I1);
    C2 = CHARACTER(S1);
    C3 = CHARACTER(C1);
    I2 = INTEGER(C4);
    S2 = SCALAR(C5);
    WRITE(6) C1;
    WRITE(6) C2;
    WRITE(6) C3;
    WRITE(6) 'I2=', I2;
    WRITE(6) 'S2=', S2;
 CLOSE TEST_CHAR_CONV;
