 TEST_ERRFIX_SCALAR:
 PROGRAM;
    DECLARE SCALAR, NEG4 INITIAL(-4.0);
    DECLARE SCALAR, ZERO INITIAL(0.0);
    DECLARE SCALAR, NEG5 INITIAL(-5.0);
    DECLARE SCALAR, BIG INITIAL(200.0);
    DECLARE SCALAR, NEGBASE INITIAL(-8.0);
    DECLARE SCALAR, ONETHIRD INITIAL(0.3333333);
    DECLARE SCALAR, NEGONE INITIAL(-1.0);
    DECLARE SCALAR, RESULT;
    WRITE(6) SQRT(NEG4);
    WRITE(6) LOG(ZERO);
    WRITE(6) LOG(NEG5);
    WRITE(6) EXP(BIG);
    RESULT = NEGBASE**ONETHIRD;
    WRITE(6) RESULT;
    RESULT = ZERO**NEGONE;
    WRITE(6) RESULT;
    RESULT = ZERO**0;
    WRITE(6) RESULT;
    RESULT = ZERO**(-1);
    WRITE(6) RESULT;
 CLOSE TEST_ERRFIX_SCALAR;
