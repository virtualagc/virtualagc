 TEST_SCALAR_EXP:
 PROGRAM;
    DECLARE SCALAR, S1 INITIAL(2.0), S2, S3, S4, S5;
    DECLARE INTEGER, N INITIAL(3);
    DECLARE INTEGER, M INITIAL(-2);
    S2 = S1 ** 3;
    S3 = S1 ** N;
    S4 = S1 ** M;
    S5 = S1 ** 0.5;
    WRITE(6) S2;
    WRITE(6) S3;
    WRITE(6) S4;
    WRITE(6) S5;
 CLOSE TEST_SCALAR_EXP;
