 TEST_NEST_CALL: PROGRAM;
    DECLARE P5D MATRIX(5,5) INITIAL(4#(1,5#0),1);

    PRINT_MATRIX_5D: PROCEDURE(M);
        DECLARE M MATRIX(5,5);
        DO FOR TEMPORARY I = 1 TO 5;
           WRITE(6) '', M$(I,*);
        END;
    CLOSE PRINT_MATRIX_5D;

    PRINT_MATRIX_5D2: PROCEDURE(M);
        DECLARE M MATRIX(5,5);
        CALL PRINT_MATRIX_5D(M);
    CLOSE PRINT_MATRIX_5D2;

    CALL PRINT_MATRIX_5D2(P5D);

 CLOSE TEST_NEST_CALL;
