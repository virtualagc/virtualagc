 TEST_STRUCT:
 PROGRAM;
    STRUCTURE ZQTEMPLATE:
       1 QI INTEGER,
       1 QS SCALAR;
    DECLARE
       ZQ1  ZQTEMPLATE-STRUCTURE,
       ZQ2  ZQTEMPLATE-STRUCTURE,
       ZQ3  ZQTEMPLATE-STRUCTURE;
    ZQ1.QI = 5;
    ZQ1.QS = 2.5;
    ZQ2.QI = 5;
    ZQ2.QS = 2.5;
    ZQ3.QI = 9;
    ZQ3.QS = 2.5;
    IF ZQ1 = ZQ2 THEN
       WRITE(6) 'TEQU-TRUE';
    IF ZQ1 ¬= ZQ3 THEN
       WRITE(6) 'TNEQ-TRUE';
    ZQ3 = ZQ1;
    WRITE(6) ZQ3.QI;
    IF ZQ1 = ZQ3 THEN
       WRITE(6) 'TASN-COPIED';
 CLOSE TEST_STRUCT;
