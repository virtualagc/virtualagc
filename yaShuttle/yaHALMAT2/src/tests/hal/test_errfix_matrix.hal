 TEST_ERRFIX_MATRIX:
 PROGRAM;
    DECLARE SNG MATRIX(2, 2) INITIAL(1.0, 2.0, 2.0, 4.0);
    DECLARE VZ VECTOR(3) INITIAL(0.0, 0.0, 0.0);
    DECLARE M2 MATRIX(2, 2) INITIAL(1.0, 2.0, 3.0, 4.0);
    WRITE(6) INVERSE(SNG);
    WRITE(6) UNIT(VZ);
    WRITE(6) M2**2;
    WRITE(6) M2**0;
    WRITE(6) M2**(-1);
    WRITE(6) SNG**(-1);
    WRITE(6) M2 / 0.0;
 CLOSE TEST_ERRFIX_MATRIX;
