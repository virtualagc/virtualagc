 TEST_ERON_GOTO_APPC:
 PROGRAM;
    DECLARE SCALAR, NEG4 INITIAL(-4.0);
    DECLARE SCALAR, RESULT;
    DECLARE VZ VECTOR(3) INITIAL(0.0, 0.0, 0.0);
    DECLARE M2 MATRIX(2, 2) INITIAL(1.0, 2.0, 3.0, 4.0);
    DECLARE ZERO SCALAR INITIAL(0.0);

    ON ERROR$(4:5) GO TO AFTERSQRT;
    RESULT = SQRT(NEG4);
    WRITE(6) 'SHOULD NOT PRINT (SQRT)', RESULT;
    AFTERSQRT: ON ERROR$(4:5) SYSTEM;
    WRITE(6) 'AFTER SQRT TRAP';

    ON ERROR$(4:28) GO TO AFTERUNIT;
    WRITE(6) UNIT(VZ);
    WRITE(6) 'SHOULD NOT PRINT (UNIT)';
    AFTERUNIT: ON ERROR$(4:28) SYSTEM;
    WRITE(6) 'AFTER UNIT TRAP';

    ON ERROR$(4:25) GO TO AFTERMDIV;
    WRITE(6) M2 / ZERO;
    WRITE(6) 'SHOULD NOT PRINT (MDIV)';
    AFTERMDIV: ON ERROR$(4:25) SYSTEM;
    WRITE(6) 'AFTER MDIV TRAP';

    ON ERROR$(4:4) GO TO AFTERZEROPOW;
    RESULT = ZERO**0;
    WRITE(6) 'SHOULD NOT PRINT (ZEROPOW)', RESULT;
    AFTERZEROPOW: ON ERROR$(4:4) SYSTEM;
    WRITE(6) 'AFTER ZEROPOW TRAP';

    RESULT = SQRT(NEG4);
    WRITE(6) 'RESTORED SQRT', RESULT;
 CLOSE TEST_ERON_GOTO_APPC;
