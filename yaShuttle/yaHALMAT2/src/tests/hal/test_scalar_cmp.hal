 TEST_SCALAR_CMP:
 PROGRAM;
    DECLARE SCALAR, S1 INITIAL(3.0), S2 INITIAL(5.0);
    DECLARE INTEGER, X INITIAL(1), Y INITIAL(9);
    IF S1 < S2 THEN
       WRITE(6) 'LESS';
    IF S1 = S1 THEN
       WRITE(6) 'EQUAL';
    IF (X > 0) & (Y > 5) THEN
       WRITE(6) 'AND-TRUE';
    IF NOT (S1 > S2) THEN
       WRITE(6) 'NOT-TRUE';
 CLOSE TEST_SCALAR_CMP;
