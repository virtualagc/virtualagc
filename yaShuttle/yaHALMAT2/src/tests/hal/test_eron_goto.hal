 TEST_ERON_GOTO:
 PROGRAM;
    DECLARE SNG MATRIX(2, 2) INITIAL(1.0, 2.0, 2.0, 4.0);
    DECLARE A MATRIX(2, 2);
    A = INVERSE(SNG);
    WRITE(6) 'BEFORE TRAP', A;
    ON ERROR$(4:27) GO TO SKIPPED;
    WRITE(6) 'AFTER ON ERROR';
    A = INVERSE(SNG);
    WRITE(6) 'SHOULD NOT PRINT', A;
    SKIPPED: ON ERROR$(4:27) SYSTEM;
    WRITE(6) 'AFTER SKIPPED LABEL';
    A = INVERSE(SNG);
    WRITE(6) 'AFTER RESTORE', A;
 CLOSE TEST_ERON_GOTO;
