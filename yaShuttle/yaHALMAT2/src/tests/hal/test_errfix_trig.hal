 TEST_ERRFIX_TRIG:
 PROGRAM;
    DECLARE SCALAR, BIGARG INITIAL(900000.0);
    DECLARE SCALAR, HUGESCALAR INITIAL(50000000000.0);
    DECLARE INTEGER, IRESULT;
    WRITE(6) TAN(BIGARG);
    WRITE(6) SIN(BIGARG);
    WRITE(6) COS(BIGARG);
    IRESULT = INTEGER(HUGESCALAR);
    WRITE(6) IRESULT;
 CLOSE TEST_ERRFIX_TRIG;
