 COMPB: COMPOOL;
    STRUCTURE ASTRUCTURE: /* Exactly like in COMPA */
       1 SI INTEGER,
       1 SL BOOLEAN,
       1 SS SCALAR,
       1 SC CHARACTER(20);
    DECLARE BSTRUCTURE ASTRUCTURE-STRUCTURE;
    DECLARE 
        IB INTEGER, 
        BB BIT(16),
        SB SCALAR,
        CB CHARACTER(30);
 CLOSE COMPB;
