#!/usr/bin/env python
'''
This program is declared by its author, Ronald Burkey, to be in the Public
Domain in the U.S., and may be used, modified, or distributed in any manner
whatsoever, free of charge.

This Python 3 script is intended to supersede (providing full functionality
across all platforms) the predecessor bash script HALSFC and the hopefully-
equivalent Windows batch file HALSFC.bat.  The only difference, other than
possibly increased functionality, is that command-line parameters are no longer
positional.

(There's just one little problem that I discovered belatedly -- i.e., after 
writing this entire thing.  Namely, it's so insanely difficult in Windows to
run any Python script that isn't in the current working directory, that it's 
completely useless!  Yay!)

This Linux/Mac script compiles a HAL/S program using the HAL/S-FC program,
which is assumed to be in the PATH.  ERRORLIB is assumed to be in the same
folder as HALSFC-PASS1.
'''

import sys
import os
import platform
import shutil
from datetime import datetime
from pathlib import Path

# Detect the platform.  Our only concern is Windows vs non-Windows, since I 
# assume that all non-Windows platforms are some *nix flavor.  Note that when
# python is run in an MSYS2 environment, it does *not* detect Windows,
# which is just what we want.
isWindows = (platform.system() == "Windows")
# Just in case of working with .exe files in WINE.
if not isWindows:
    os.environ['WINEDEBUG'] = '-all'

helpMessage = '''
This script compiles a HAL/S source-code file to a HALMAT "intermediate 
language" file and to AP-101S object-code file(s), using "modern" ports of the 
original Intermetrics/USA HAL/S compiler HAL/S-FC.  It requires that all 
compiler passes (HALSFC-PASS1[.exe], etc.) be in the PATH.

     HALSFC [OPTIONS] SOURCE.hal

NOTE:  If SOURCE.hal begins with "_" (underscore) or with "./_" (or in Windows,
".\\_"), it will be *moved* to the results directory rather than merely copied 
there.  So use of an underscore at the beginning of your HAL/S filename is 
therefore not recommended.  That's because names of HAL/S files generated by 
preprocessing prior to compilation are typically prefixed by underscores,
making it desirable not to retain them.

The available OPTIONS are:

    -o F             Saves generated object file with file- or folder-name F 
                     rather than just as the default cards.bin (for PFS/PASS) or 
                     cards/ (for BFS).
    --test           In addition to compiling, perform all available validity
                     tests. Requires NOTABLES in --parms (see below).  Also
                     requires that the following be installed and be in the PATH: 
                     diff[.exe], egrep[.exe], and HAL_S_FC.py.
    --force          Forces a HAL_S_FC.py compilation to occur even if
                     HALSFC-PASS1[.exe] has failed.
    --parms="..."    Comma-separated list of HAL/S-FC options. For compatibility 
                     with Windows, it is good practice to enclose this in 
                     double-quotes.  If you do not supply --parms, or if the 
                     "CARDTYPE=..." compiler option is not present in it, 
                     HALSFC supplies a default CARDTYPE, namely either 
                     CARDTYPE=UDVMWCXCYMZC for --bfs (see below) or else
                     CARDTYPE=UDVMWCXCYCZM if no --bfs (i.e., for PFS).
    --no-opt         Do not run optimization passes, and try to generate object
                     code from unoptimized HALMAT.
    --bfs            Use BFS version of HAL/S-FC.  The default is the PASS/PFS 
                     version of HAL/S-FC.
    --exe            Use Windows port of HAL/S-FC.  This is the default on
                     Windows, but it can be done on Linux or MacOS as well if
                     the Windows version of HAL/S-FC is installed and if the
                     WINE package is installed for running Windows executables.
    --clean          Remove all of the workfiles and results generated by the
                     compiler from the current directory (preserving them *only*
                     in the results directory).
    --archive        Causes the results directories ("HALSFC ...".results) to
                     appear in a directory called archive.results rather than
                     in the current working directory.
    --debug=X        A debugging-mode flagword to pass directly to the 
                     HALSFC-XXXX compiler passes.  X is a hexadecimal number
                     whose present interpretation is:
                         Bit 0:  PASS2:  Print messages in `SAVE_LITERAL`.
                         Other:  Ignored.
    --pretty-bnf     Use improved alternate production trace to "DEBUG `8".
    --rsb-trace=N    Activate my production trace, if available.
    --debug-literals Show extra messages in HAL_S_FC.py report for literals.
    --verbose        Show the command lines for HALSFC-xxx and HAL_S_FC.py.
    
'''

# Parse the command line.
halsFile = None
test = False
force = False
cardType = "UDVMWCXC"
parmString = ""
bfs = False
ext = ""
rsbTrace = ""
objectFilename = None
oWasLast = False
extCOMMON = ".out"
debugX = ''
prettyBNF = ""
verbose = False
debugLiterals = ""
clean = False
archive = False
if isWindows:
    ext = ".exe"
for parm in sys.argv[1:]:
    if oWasLast:
        oWasLast = False
        if parm.startswith("-"):
            print("-o followed by aswitch rather than an object-code filename")
            sys.exit(1)
        elif parm.endswith(".hal"):
            print("-o followed by a source-code filename rather than an object-code filename")
            sys.exit(1)
        objectFilename = parm
    elif parm == "--pretty-bnf":
        prettyBNF = parm
    elif parm == "--verbose":
        verbose = True
    elif parm == "--debug-literals":
        debugLiterals = parm
    elif parm == "-o":
        oWasLast = True
    elif parm == "--test":
        test = True
    elif parm == "--force":
        force = True
    elif parm.startswith("--parms="):
        parmString = parm[8:]
    elif parm == "--bfs":
        bfs = True
    elif parm == "--exe":
        ext = ".exe"
    elif parm.startswith("--debug="):
        debugX = parm
    elif parm.startswith("--rsb-trace="):
        rsbTrace = parm
    elif parm == "--clean":
        clean = True
    elif parm == "--archive":
        archive = True
    elif not parm.startswith("-"):
        if halsFile != None:
            print("Multiple HAL/S files specified")
            sys.exit(1)
        halsFile = parm
        if not os.path.exists(halsFile):
            print("Specified HAL/S file (%s) does not exist" % halsFile)
            sys.exit(1)
    else:
        print(helpMessage)
        if parm == "--help":
            sys.exit(0)
        sys.exit(1)
if "CARDTYPE=" not in parmString:
    if parmString != "":
        parmString += ","
    if bfs:
        cardType += "YMZC"
    else:
        cardType += "YCZM"
    parmString += f"CARDTYPE={cardType}"
if halsFile == None:
    print(helpMessage)
    sys.exit(1)
if oWasLast:
    print("-o followed by end of line rather than an object-code filename")
    sys.exit(1)
normFile = Path(halsFile).name
commandLine = " ".join(sys.argv)
if objectFilename == None:
    if bfs:
        objectFilename = "cards"
    else:
        objectFilename = "cards.bin"

now = datetime.now()
now = now.strftime("%Y-%m-%d %H-%M-%S")

filesPorted = ["FILE4.bin", "FILE5.bin", 
               "FILE6.bin", "&&TEMPLIB.json", "&&TEMPINC.json", "SOURCECO.txt",
               "$FILES_PORTED", "SYM_TAB.json", "$FILES_PORTED", 
               "CROSS_REF.json"]
filesLocal = ["LISTING2p.txt", "vmem.bin", "COMMON1.out", "COMMON2.out",
              "COMMON1.gz", "COMMON3.gz", "COMMON4.gz", 
              "COMMON4.out", "auxmat.bin", "objcode.bin",
              "COMMON1.out.bin.gz", "COMMON3.out.bin.gz", 
              "pass1A.rpt", "pass1pA.rpt", 
              "aux.rpt", "pass3.rpt", "pass4.rpt", "monitor13.parms",
              "deck.bin", "extra.txt", "&&TEMPINC",
              "litfile1.bin", "litfile3.bin", "literals1.txt", "literals1p.txt"]
filesPreserve = ["litfile.bin", "cards", "COMMON0.out", "COMMON0.out.bin.gz", 
                 "litfile0.bin", "litfile2.bin", "COMMON2.out.bin.gz",
                 "FILE1.bin", "FILE2.bin", "LIT_CHAR.bin",
                 "pass1.rpt", "pass1p.rpt", 
                 "opt.rpt", "pass2.rpt", "cards.bin", "listing2.txt", 
                 "optmat.bin", "halmat.bin", "FILE3.bin", "icfile.bin",
                 "auxp.rpt", "flo.rpt", "COMMON4.out.bin.gz", "litfile4.bin",
                 "COMMON3.out"]
filesReallyPreserve = ["TEMPLIB.json", "TEMPLIBB.json", 
                       "INCLIB.json", "INCLIBB.json"]
dirsReallyPreserve = ["TEMPLIB", "TEMPLIBB", 
                       "INCLIB", "INCLIBB"]
if clean:
    filesLocal += filesPreserve
    filesPreserve = []
for f in filesPorted+filesLocal+filesPreserve:
    try:
        os.remove(f)
    except:
        pass

# Move all generated files to a *.results folder.
results = ""
def moveAll(message):
    global results
    results = "HALSFC %s %s.results" % (normFile, now)
    if archive:
        try:
            os.mkdir("archive.results")
        except:
            pass
        results = f"archive.results{os.sep}{results}"
    os.mkdir(results);
    f = open("%s%scomment.txt" % (results, os.sep), "w")
    print(message, file=f)
    f.close()
    try:
        if bfs:
            if objectFilename != "cards":
                try:
                    shutil.rmtree(objectFilename)
                except:
                    pass
                shutil.copytree("cards", objectFilename)
        else:
            if objectFilename != "cards.bin":
                shutil.copy("cards.bin", objectFilename)
    except:
        print(f"FYI: Unable to copy object file(s) to {objectFilename}")
    if halsFile.startswith("_") or halsFile.startswith(f".{os.sep}_"):
        extras1 = [halsFile]
        extras2 = []
    else:
        extras1 = []
        extras2 = [halsFile]
    for f in filesPorted+filesLocal + extras1:
        try:
            shutil.move(f, "%s%s%s" % (results, os.sep, f))
        except:
            pass
    for f in filesPreserve+filesReallyPreserve+extras2:
        try:
            shutil.copy(f, "%s%s%s" % (results, os.sep, f))
        except:
            pass
    for d in dirsReallyPreserve:
        try:
            shutil.copytree(d, "%s%s%s" % (results, os.sep, d))
        except:
            pass
    print(f"Results stored in the folder \"{results}\".")
    numBackups = 2
    previous = ""
    for i in range(numBackups, 0, -1):
        try:
            os.remove(f"current-{i}.results")
        except:
            pass
        if i == 1:
            dest = ""
        else:
            dest = f"-{i-1}"
        try:
            shutil.move(f"current{dest}.results", f"current-{i}.results")
            if previous == "":
                previous = f"\"current-{i}.results\""
            else:
                previous = f"\"current-{i}.results\", {previous}"
        except:
            pass
    try:
        os.symlink(results, "current.results", target_is_directory=True)
        print("Accessible also as \"current.results\" until next HALSFC run.")
        if previous != "":
            print(f"For previous runs see also {previous}.")
    except:
        pass

# The arguments comprise an error message.
def errorExit(message):
    print(message)
    moveAll("%s: %s" % (message, commandLine))
    sys.exit(1)

# Adapted this from google AI.
def findFileUsingPATH(filename):
    pathVar = os.getenv("PATH")
    if not pathVar:
        return None
    directories = pathVar.split(os.pathsep)
    for directory in directories:
        if os.path.isfile(os.path.join(directory, filename)):
            return directory
    return None

if bfs:
    PASS1 = "HALSFC-PASS1B" + ext
    FLO = "HALSFC-FLO" + ext
    OPT = "HALSFC-OPTB" + ext
    AUXP = "HALSFC-AUXP" + ext
    PASS2 = "HALSFC-PASS2B" + ext
    PASS3 = "HALSFC-PASS3B" + ext
    PASS4 = "HALSFC-PASS4" + ext
    TEMPLIB = "TEMPLIBB"
    INCLIB = "INCLIBB"
    INCLIB2 = "&&TEMPINC"
    CARDS = "--pdso=3,cards,E"
    TARGET = "--bfs"
else:
    PASS1 = "HALSFC-PASS1" + ext
    FLO = "HALSFC-FLO" + ext
    OPT = "HALSFC-OPT" + ext
    AUXP = "HALSFC-AUXP" + ext
    PASS2 = "HALSFC-PASS2" + ext
    PASS3 = "HALSFC-PASS3" + ext
    PASS4 = "HALSFC-PASS4" + ext
    TEMPLIB = "TEMPLIB"
    INCLIB = "INCLIB"
    INCLIB2 = "&&TEMPINC"
    CARDS = "--ddo=3,cards.bin,E"
    TARGET = "--pfs"

appDir = findFileUsingPATH(PASS1)
if appDir == None:
    print("Directory containing the compiler is not in the PATH")
    sys.exit(1)
ERRORLIB = appDir + os.sep + "ERRORLIB"
parmList = parmString.split(",")

# Run PASS1.
command ='''%s
 --parm="%s"
 --ddi=0,"%s"
 --ddo=2,listing2.txt
 --pdsi=4,%s,E
 --pdsi=5,"%s"
 --pdsi=6,ACCESS
 --pdso=6,%s,E
 --pdsi=8,%s,E
 --pdso=8,"%s",E
 --pdsi=9,"%s",E
 --commono=COMMON0%s
 --raf=O,7200,1,halmat.bin
 --raf=B,1560,2,litfile.bin
 --raf=B,1600,3,icfile.bin
 --raf=B,3360,6,vmem.bin
 %s
 %s
 %s
 >pass1.rpt''' % (PASS1, parmString, halsFile, TEMPLIB, ERRORLIB, TEMPLIB, 
                 INCLIB, INCLIB2, INCLIB2, extCOMMON, debugX, rsbTrace,
                 prettyBNF)
#print(f"Here {command}", file=sys.stderr)
command = command.replace("\n", "")
if verbose:
    print(command)
exitCode = os.system(command)
pendingFailure = None
if exitCode != 0:
    if test and force:
        print("HALSFC-PASS1 has failed, but --test will be performed anyway.")
        pendingFailure = "HALSFC-PASS1 failure"
    else:
        errorExit("Aborted after PASS1")
shutil.copy("litfile.bin", "litfile0.bin")
if False:
    shutil.copy("COMMON0.out", "temp")
    shutil.copy("halmat.bin", "temp")
    shutil.copy("litfile.bin", "temp")
    shutil.copy("vmem.bin", "temp")

# Maybe run PASS1 tests. 
if test:
    sys.stdout.flush()
    print("======================================================")
    sys.stdout.flush()
    diff = "diff" + ext
    egrep = "egrep" + ext
    if None == findFileUsingPATH(diff):
        errorExit("Not available for --test:  " + diff )
    if None == findFileUsingPATH(egrep):
        errorExit("Not available for --test:  " + egrep)
    ported=findFileUsingPATH("HAL_S_FC.py")
    if ported == None:
        errorExit("Not available for --test:  HAL_S_FC.py")
    fullPath = os.path.join(ported, "HAL_S_FC.py")
    ported=Path(ported).parent
    if ported == None:
        errorExit("Not available for --test:  HAL_S_FC.py")
    command = 'python "%s" %s %s %s %s %s --templib --hal="%s" >pass1p.rpt' \
                         % (fullPath, TARGET, parmString.replace(",", " "), 
                            rsbTrace, prettyBNF, debugLiterals, halsFile)
    #print(command)
    if verbose:
        print(command)
    exitCode = os.system(command)
    if exitCode:
        if force:
            if pendingFailure == None:
                pendingFailure = ""
            else:
                pendingFailure += ", "
            pendingFailure += "HAL_S_FC.py failure"
        else:
            errorExit("Failed PASS1 cross-comparison test")
    sys.stdout.flush()
    print("PASS1 cross-comparison test:")
    sys.stdout.flush()
    for n in filesPorted:
        try:
            shutil.copy(os.path.join(ported, n), n)
        except:
            pass
    IGNORE_LINES='(HAL/S|FREE STRING AREA|NUMBER OF FILE 6|PROCESSING RATE|CPU TIME FOR|TODAY IS|COMPOOL.*VERSION|^REALLOCATIONS|^ *$|SRN STMT|^.[-]+$)'
    os.system('egrep -v "%s" pass1.rpt >pass1A.rpt' % IGNORE_LINES)
    os.system('egrep -v "%s" pass1p.rpt >pass1pA.rpt' % IGNORE_LINES)
    os.system('diff --strip-trailing-cr -q -s pass1A.rpt pass1pA.rpt')
    os.system('diff -s FILE1.bin halmat.bin')
    if Path("FILE3.bin").is_file() and Path("icfile.bin").is_file():
        os.system('diff -s FILE3.bin icfile.bin')
    else:
        print("FYI: No IC file produced for testing")
    os.system('unLitfile FILE2.bin >literals1p.txt')
    os.system('unLitfile litfile0.bin >literals1.txt')
    os.system('diff --strip-trailing-cr -q -s literals1.txt literals1p.txt')
    if "LISTING2" in parmList:
            os.system('diff --strip-trailing-cr -q -s LISTING2p.txt listing2.txt')
    sys.stdout.flush()
    print("======================================================")
    sys.stdout.flush()
if pendingFailure != None:
    errorExit(f"Aborting due to deferred {pendingFailure}.")

# Run FLO.
command = '''%s 
 --commoni=COMMON0%s 
 --commono=COMMON1%s 
 --pdsi=5,"%s" 
 --raf=I,7200,1,halmat.bin 
 --raf=I,1560,2,litfile.bin 
 --raf=B,3360,6,vmem.bin 
 %s
 >flo.rpt''' % (FLO, extCOMMON, extCOMMON, ERRORLIB, debugX)
#print(command, file=sys.stderr)
command = command.replace("\n", "")
if verbose:
    print(command)
exitCode = os.system(command)
if exitCode != 0:
    errorExit("Aborted after FLO")
shutil.copy("litfile.bin", "litfile1.bin")

# Run OPT.
command = '''%s 
 --commoni=COMMON1%s 
 --commono=COMMON2%s 
 --pdsi=5,"%s" 
 --raf=I,7200,1,halmat.bin 
 --raf=B,1560,2,litfile.bin 
 --raf=O,7200,4,optmat.bin 
 --raf=B,3360,6,vmem.bin 
 %s
 >opt.rpt''' % (OPT, extCOMMON, extCOMMON, ERRORLIB, debugX)
exitCode = os.system(command.replace("\n", ""))
if exitCode != 0:
    errorExit("Aborted after OPT")
shutil.copy("litfile.bin", "litfile2.bin")

# Run AUX.
command = '''%s 
 --commoni=COMMON2%s 
 --commono=COMMON3%s 
 --pdsi=5,"%s" 
 --raf=O,7200,1,auxmat.bin 
 --raf=I,1560,2,litfile.bin 
 --raf=I,7200,4,optmat.bin 
 --raf=B,3360,6,vmem.bin 
 %s
 >auxp.rpt''' % (AUXP, extCOMMON, extCOMMON, ERRORLIB, debugX)
command = command.replace("\n", "")
if verbose:
    print(command)
exitCode = os.system(command)
if exitCode != 0:
    errorExit("Aborted after AUX")
shutil.copy("litfile.bin", "litfile3.bin")

# Run PASS2
command = '''%s 
 %s 
 --ddo=4,deck.bin,E 
 --pdsi=5,"%s" 
 --ddo=7,extra.txt 
 --commoni=COMMON3%s 
 --commono=COMMON4%s 
 --raf=I,7200,1,auxmat.bin 
 --raf=B,1560,2,litfile.bin 
 --raf=B,1600,3,objcode.bin 
 --raf=I,7200,4,optmat.bin 
 --raf=B,3360,6,vmem.bin 
 %s
 >pass2.rpt''' % (PASS2, CARDS, ERRORLIB, extCOMMON, extCOMMON, debugX)
command = command.replace("\n", "")
if verbose:
    print(command)
exitCode = os.system(command)
if exitCode != 0:
    errorExit("Aborted after PASS2")
shutil.copy("litfile.bin", "litfile4.bin")

# PASS3 and PASS4 aren't ready for use yet.

moveAll(f"Success: {' '.join(sys.argv)}")
print("Compilation successful.")
