 TEST_STOI:
 PROGRAM;
    DECLARE SCALAR, S1 INITIAL(7.2);
    DECLARE SCALAR, S2 INITIAL(7.5);
    DECLARE SCALAR, S3 INITIAL(-7.5);
    DECLARE SCALAR, S4 INITIAL(-7.2);
    DECLARE INTEGER, I1, I2, I3, I4;
    I1 = INTEGER(S1);
    I2 = INTEGER(S2);
    I3 = INTEGER(S3);
    I4 = INTEGER(S4);
    WRITE(6) 'I1=', I1, 'I2=', I2, 'I3=', I3, 'I4=', I4;
 CLOSE TEST_STOI;
