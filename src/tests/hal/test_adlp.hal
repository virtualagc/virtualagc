 TEST_ADLP2:
 PROGRAM;
    DECLARE A1 ARRAY(3) SCALAR;
    DECLARE A2 ARRAY(3) SCALAR;
    DECLARE A3 ARRAY(3) SCALAR;
    DECLARE SCALAR, VAL;
    A1 = 1.0;
    A2 = 2.0;
    A3 = A1 + A2;
M   VAL = A3  ;
S           1
    WRITE(6) VAL;
M   VAL = A3  ;
S           2
    WRITE(6) VAL;
M   VAL = A3  ;
S           3
    WRITE(6) VAL;
 CLOSE TEST_ADLP2;
