 TEST_VSHP:
 PROGRAM;
    DECLARE SCALAR, S1 INITIAL(1.0);
    DECLARE SCALAR, S2 INITIAL(2.0);
    DECLARE SCALAR, S3 INITIAL(3.0);
    DECLARE V VECTOR(3);
    DECLARE SCALAR, VAL;
    V = VECTOR(S1, S2, S3);
M   VAL = V   ;
S          1
    WRITE(6) VAL;
M   VAL = V   ;
S          2
    WRITE(6) VAL;
M   VAL = V   ;
S          3
    WRITE(6) VAL;
 CLOSE TEST_VSHP;
