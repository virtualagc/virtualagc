 TEST_MATRIX_SUB:
 PROGRAM;
    DECLARE M MATRIX(2, 3);
    DECLARE SCALAR, VAL;
M   M    = 1.0;
S    1,1
M   M    = 2.0;
S    1,2
M   M    = 3.0;
S    1,3
M   M    = 4.0;
S    2,1
M   M    = 5.0;
S    2,2
M   M    = 6.0;
S    2,3
M   VAL = M   ;
S          2,2
    WRITE(6) VAL;
M   VAL = M   ;
S          1,3
    WRITE(6) VAL;
M   VAL = M   ;
S          2,1
    WRITE(6) VAL;
 CLOSE TEST_MATRIX_SUB;
