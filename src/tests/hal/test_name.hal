 TEST_NAME:
 PROGRAM;
    DECLARE SCALAR, S1, S2;
    DECLARE NS1 NAME SCALAR;
    DECLARE NS2 NAME SCALAR;
    NAME(NS1) = NAME(S1);
    NAME(NS2) = NAME(S1);
    IF NAME(NS1) = NAME(NS2) THEN
       WRITE(6) 'NEQU-TRUE';
    NAME(NS2) = NAME(S2);
    IF NAME(NS1) ¬= NAME(NS2) THEN
       WRITE(6) 'NNEQ-TRUE';
 CLOSE TEST_NAME;
