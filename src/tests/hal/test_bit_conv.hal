 TEST_BIT_CONV:
 PROGRAM;
    DECLARE BIT(8), B1, B2, B3;
    DECLARE SCALAR, S1;
    DECLARE CHARACTER(10), C1 INITIAL('99');
    B1 = BIT(12);
    B2 = BIT(12);
    S1 = SCALAR(B1);
    WRITE(6) S1;
    C1 = CHARACTER(B1);
    WRITE(6) C1;
    IF B1 = B2 THEN
       WRITE(6) 'BEQU-TRUE';
    B3 = BIT(C1);
    WRITE(6) INTEGER(B3);
 CLOSE TEST_BIT_CONV;
