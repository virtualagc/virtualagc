 TEST_INIT8:
 PROGRAM;
    DECLARE BIT(16), B1 INITIAL(BIN'1010101010101010');
    DECLARE M MATRIX(2,2) INITIAL(9.0);
    DECLARE V VECTOR(3) INITIAL(4.0);
    DECLARE SCALAR, VAL;
    WRITE(6) INTEGER(B1);
M   VAL = M   ;
S          1,1
    WRITE(6) VAL;
M   VAL = M   ;
S          2,2
    WRITE(6) VAL;
M   VAL = V   ;
S          2
    WRITE(6) VAL;
 CLOSE TEST_INIT8;
